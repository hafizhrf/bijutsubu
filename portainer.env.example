# Use these keys as the Portainer Git stack environment variables.
BIJUTSUBU_BACKEND_IMAGE=ghcr.io/hafizhrf/bijutsubu-backend:replace-with-commit-sha
BIJUTSUBU_FRONTEND_IMAGE=ghcr.io/hafizhrf/bijutsubu-frontend:replace-with-commit-sha
MONGODB_URI=mongodb://mongo:27017/bijutsubu
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
CORS_ORIGIN=https://bijutsubu.hafizhrf.me
DIFY_BASE_URL=
DIFY_DATASET_API_KEY=
UPLOAD_RATE_LIMIT_MINUTES=5
GENUI_RATE_LIMIT_MINUTES=5
UPLOAD_MAX_FILE_SIZE_MB=15
KB_UPLOAD_RATE_LIMIT_MINUTES=5
KB_CHAT_RATE_LIMIT_MINUTES=1
SOURCE_CREDENTIAL_ENC_KEY=replace-with-a-random-32-byte-secret
SOURCE_SYNC_RATE_LIMIT_MINUTES=5
SOURCE_ALLOW_PRIVATE_HOSTS=false
SOURCE_SYNC_MAX_ROWS=50000
ADMIN_EMAILS=
