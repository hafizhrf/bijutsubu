PORT=4000
MONGODB_URI=mongodb://localhost:27017
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# OpenAI-compatible LLM config
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Rate limit windows, in minutes. Product default is 5; set to 1 for current testing.
UPLOAD_RATE_LIMIT_MINUTES=1
GENUI_RATE_LIMIT_MINUTES=1

# Upload constraints
UPLOAD_MAX_FILE_SIZE_MB=15

CORS_ORIGIN=http://localhost:5173

# Dify knowledge base (dataset-scoped API key — NOT an app/chat key)
DIFY_BASE_URL=https://your-dify-host/v1
DIFY_DATASET_API_KEY=dataset-your-key-here
KB_UPLOAD_RATE_LIMIT_MINUTES=1
KB_CHAT_RATE_LIMIT_MINUTES=0.2

# External data sources (MySQL/MariaDB, PostgreSQL, MongoDB)
# Encrypts saved DB passwords at rest (AES-256-GCM). Optional: when unset, a
# key is derived from JWT_SECRET — set an explicit random key in production.
SOURCE_CREDENTIAL_ENC_KEY=
# Manual "Sync now" cooldown, minutes.
SOURCE_SYNC_RATE_LIMIT_MINUTES=1
# Set to false on shared/SaaS deployments: rejects loopback/private/link-local
# hosts (SSRF guard). Default true because self-hosted users connect to
# localhost databases.
SOURCE_ALLOW_PRIVATE_HOSTS=true
# Per-table row cap per sync.
SOURCE_SYNC_MAX_ROWS=50000

# Comma-separated internal operator accounts allowed to open /admin
ADMIN_EMAILS=admin@example.com
